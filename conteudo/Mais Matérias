  <script>
    function filtrar(el, categoria) {
      document.querySelectorAll('.filtro-btn').forEach(b => b.classList.remove('ativo'));
      if (el && el.classList) el.classList.add('ativo');
      const cards = document.querySelectorAll('[data-categoria]');
      cards.forEach(c => {
        c.style.display = (categoria === 'todos' || c.dataset.categoria === categoria) ? '' : 'none';
      });
    }

    function trocarView(modo) {
      const grade = document.getElementById('view-grade');
      const lista = document.getElementById('view-lista');
      const btnG = document.getElementById('btn-grade');
      const btnL = document.getElementById('btn-lista');
      if (modo === 'grade') {
        grade.style.display = 'grid';
        lista.style.display = 'none';
        btnG.classList.add('ativo'); btnL.classList.remove('ativo');
      } else {
        grade.style.display = 'none';
        lista.style.display = 'flex';
        btnL.classList.add('ativo'); btnG.classList.remove('ativo');
      }
    }

    function buscar(termo) {
      const t = termo.toLowerCase();
      document.querySelectorAll('[data-categoria]').forEach(c => {
        const texto = c.textContent.toLowerCase();
        c.style.display = texto.includes(t) ? '' : 'none';
      });
    }
  </script>
